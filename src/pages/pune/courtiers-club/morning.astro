---
import Base from '../../../layouts/Base.astro';
import PainPoints from '../../../components/PainPoints.astro';
import WhatWeInclude from '../../../components/WhatWeInclude.astro';
import FormatGrid from '../../../components/FormatGrid.astro';
import PricingTable from '../../../components/PricingTable.astro';
import CoachingAddOn from '../../../components/CoachingAddOn.astro';
import ReclubSection from '../../../components/ReclubSection.astro';
import RulesTable from '../../../components/RulesTable.astro';
---
<Base title="Morning Group · Courtiers Club · Padel Community India" description="Coming soon: morning padel group at Courtiers Club, Kharadi, Pune.">

<!-- HERO -->
<section class="hero" style="border-bottom: 1px solid var(--rule); padding-top: 10vh;">
  <div class="hero-bg-word">PADEL</div>
  <div style="position:relative;z-index:2;">
    <div class="hero-eyebrow">PCI · Courtiers Club, Kharadi · Pune</div>
    <h1 class="hero-title">
      Courtiers Club.<br>
      <span>Morning.</span>
    </h1>
    <p class="hero-sub">
      [DETAILS TBD] A private padel subscription for intermediate and above players at Courtiers Club, Kharadi. Coming soon.
    </p>
    <div class="hero-meta">
      <div class="meta-item">
        <span class="meta-label">Venue</span>
        <span class="meta-value">Courtiers Club</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Time</span>
        <span class="meta-value">[TBD]</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Days</span>
        <span class="meta-value">Mon – Fri</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Spots</span>
        <span class="meta-value lime">24</span>
      </div>
    </div>
  </div>
</section>

<PainPoints />

<WhatWeInclude />

<FormatGrid />

<PricingTable tbc={true} launchDate="[DATE TBD]" />

<CoachingAddOn />

<ReclubSection />

<RulesTable />

<!-- CTA -->
<section class="cta-section">
  <h2 class="cta-headline">
    Interested?<br><span>Get notified.</span>
  </h2>
  <p class="cta-sub">This group is coming soon. WhatsApp us to join the waitlist.</p>
  <div class="cta-actions">
    <a href="https://wa.me/918007306165" class="cta-btn cta-btn-primary" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Join the waitlist
    </a>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-brand">Padel Community India</div>
  <div class="footer-note">Courtiers Club, Kharadi · Mon–Fri · Inter(+) · Coming Soon</div>
</footer>

</Base>
