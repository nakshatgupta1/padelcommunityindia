---
import Page from '../../../layouts/Page.astro';
---
<Page title="Courtiers Club, Kharadi · Padel Community India" description="Courtiers Club, Kharadi, Pune — PCI's second venue. Coming soon.">

<!-- HERO -->
<section class="hero" style="border-bottom: 1px solid var(--rule); padding-top: 10vh; min-height: 60vh;">
  <div class="hero-bg-word">COURT</div>
  <div style="position:relative;z-index:2;">
    <div class="hero-eyebrow">PCI Pune · Courtiers Club</div>
    <h1 class="hero-title">
      Courtiers Club<br>
      <span>Kharadi, Pune.</span>
    </h1>
    <p class="hero-sub">
      [ADDRESS TBD] — Kharadi, Pune. PCI's second venue. Groups launching soon.
    </p>
  </div>
</section>

<!-- VENUE DETAIL -->
<section>
  <div class="section-label">The venue</div>
  <div class="venue-wrap" style="grid-template-columns:1fr;">
    <div class="venue-left">
      <h2 class="venue-headline">Courtiers <span>Club.</span></h2>
      <div class="venue-address">[ADDRESS TBD] · Kharadi, Pune</div>
      <p class="venue-desc">[DETAILS TBD] — Venue information coming soon.</p>
      <div class="venue-sports">
        <span class="venue-sport-tag active">Padel</span>
      </div>
    </div>
  </div>
</section>

<!-- SOCIALS -->
<section>
  <div class="section-label">Socials</div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--rule);">
    <div class="placeholder-block"><div class="placeholder-label">Instagram</div><div class="placeholder-text">[Placeholder]</div></div>
    <div class="placeholder-block"><div class="placeholder-label">LinkedIn</div><div class="placeholder-text">[Placeholder]</div></div>
  </div>
</section>

<!-- MAP -->
<section>
  <div class="section-label">Find us</div>
  <div class="placeholder-block" style="min-height:320px;">
    <div class="placeholder-label">Google Maps</div>
    <div class="placeholder-text">[Google Maps embed — Kharadi, Pune]</div>
  </div>
</section>

<!-- GROUPS -->
<section>
  <div class="section-label">PCI groups at this venue</div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--rule);">

    <a href="/pune/courtiers-club/evening" style="background:var(--black);padding:36px;text-decoration:none;display:block;transition:background 0.2s;" onmouseover="this.style.background='var(--card)'" onmouseout="this.style.background='var(--black)'">
      <div style="font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);font-weight:500;margin-bottom:12px;opacity:0.6;">Coming soon</div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:clamp(20px,3vw,32px);letter-spacing:0.04em;color:var(--white);margin-bottom:6px;">Inter(+) Late Evening</div>
      <div style="font-size:13px;color:var(--muted);font-weight:300;margin-bottom:16px;">[DETAILS TBD] · Mon–Fri · 24 spots</div>
      <div style="font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);opacity:0.5;">View group →</div>
    </a>

    <a href="/pune/courtiers-club/morning" style="background:var(--black);padding:36px;text-decoration:none;display:block;transition:background 0.2s;" onmouseover="this.style.background='var(--card)'" onmouseout="this.style.background='var(--black)'">
      <div style="font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);font-weight:500;margin-bottom:12px;opacity:0.6;">Coming soon</div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:clamp(20px,3vw,32px);letter-spacing:0.04em;color:var(--white);margin-bottom:6px;">Inter(+) Morning</div>
      <div style="font-size:13px;color:var(--muted);font-weight:300;margin-bottom:16px;">[DETAILS TBD] · Mon–Fri · 24 spots</div>
      <div style="font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);opacity:0.5;">View group →</div>
    </a>

  </div>
</section>

</Page>
