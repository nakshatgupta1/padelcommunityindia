---
import Page from '../../../layouts/Page.astro';
---
<Page title="Casa De Padel, Kharadi · Padel Community India" description="Casa De Padel at Playshire, Upper Kharadi Road, Kharadi, Pune. Two PCI padel groups: morning and late evening.">

<!-- HERO -->
<section class="hero" style="border-bottom: 1px solid var(--rule); padding-top: 10vh; min-height: 60vh;">
  <div class="hero-bg-word">CASA</div>
  <div style="position:relative;z-index:2;">
    <div class="hero-eyebrow">PCI · Kharadi, Pune</div>
    <h1 class="hero-title">
      Casa De Padel<br>
      at <span>Playshire.</span>
    </h1>
    <p class="hero-sub">
      Upper Kharadi Road, Kharadi, Pune. Rated 4.7 on Playo. Open 24x7. PCI's founding venue in Pune.
    </p>
  </div>
</section>

<!-- VENUE DETAIL -->
<section>
  <div class="section-label">The venue</div>
  <div class="venue-wrap">
    <div class="venue-left">
      <h2 class="venue-headline">Casa De Padel<br>at <span>Playshire.</span></h2>
      <div class="venue-address">Upper Kharadi Road, Kharadi, Pune</div>
      <p class="venue-desc">
        Playshire is one of Kharadi's best multi-sport complexes. A proper sports destination, not just a court booking. Casa De Padel sits inside it, which means you're playing in a facility built for people who take sport seriously. Rated 4.7 on Playo, open 24x7, and located in the heart of Kharadi's tech and residential corridor.
      </p>
      <div class="venue-sports">
        <span class="venue-sport-tag active">Padel</span>
        <span class="venue-sport-tag">Badminton</span>
        <span class="venue-sport-tag">Football</span>
        <span class="venue-sport-tag">Box Cricket</span>
        <span class="venue-sport-tag">Snooker / Pool</span>
      </div>
    </div>
    <div class="venue-right">
      <div class="venue-cafe">
        <div class="venue-cafe-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>
        </div>
        <div>
          <div class="venue-cafe-name">The Old School Kitchen</div>
          <div class="venue-cafe-desc">At the venue. Wood-fired pizza, good coffee. Wind down after a session without going anywhere.</div>
        </div>
      </div>
      <div class="venue-cafe">
        <div class="venue-cafe-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>
        </div>
        <div>
          <div class="venue-cafe-name">Afternoon's Cafe</div>
          <div class="venue-cafe-desc">At the venue. Quiet coffee and light meals. Good for a slower end to the night.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SOCIALS -->
<section>
  <div class="section-label">Socials</div>
  <div class="placeholder-block">
    <div class="placeholder-label">Instagram</div>
    <div class="placeholder-text">Instagram placeholder. Casa De Padel has no LinkedIn.</div>
  </div>
</section>

<!-- MAP -->
<section>
  <div class="section-label">Find us</div>
  <div class="placeholder-block" style="min-height:320px;">
    <div class="placeholder-label">Google Maps</div>
    <div class="placeholder-text">Upper Kharadi Road, Kharadi, Pune</div>
  </div>
</section>

<!-- GROUPS -->
<section>
  <div class="section-label">PCI groups at this venue</div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--rule);">

    <a href="/pune/casa-de-padel/evening" style="background:var(--black);padding:36px;text-decoration:none;display:block;transition:background 0.2s;" onmouseover="this.style.background='var(--card)'" onmouseout="this.style.background='var(--black)'">
      <div style="font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--lime);font-weight:500;margin-bottom:12px;">Live · July 2026</div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:clamp(20px,3vw,32px);letter-spacing:0.04em;color:var(--white);margin-bottom:6px;">Late Evening</div>
      <div style="font-size:13px;color:var(--muted);font-weight:300;margin-bottom:16px;">8 PM – Midnight · Mon–Fri · 24 members</div>
      <div style="font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--lime);">View group →</div>
    </a>

    <a href="/pune/casa-de-padel/morning" style="background:var(--black);padding:36px;text-decoration:none;display:block;transition:background 0.2s;" onmouseover="this.style.background='var(--card)'" onmouseout="this.style.background='var(--black)'">
      <div style="font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--lime);font-weight:500;margin-bottom:12px;">Live · July 2026</div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:clamp(20px,3vw,32px);letter-spacing:0.04em;color:var(--white);margin-bottom:6px;">Morning</div>
      <div style="font-size:13px;color:var(--muted);font-weight:300;margin-bottom:16px;">6 AM – 10 AM · Mon–Fri · 24 members</div>
      <div style="font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--lime);">View group →</div>
    </a>

  </div>
</section>

</Page>
