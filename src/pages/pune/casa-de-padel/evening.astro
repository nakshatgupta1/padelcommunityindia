---
import Base from '../../../layouts/Base.astro';
import PainPoints from '../../../components/PainPoints.astro';
import WhatWeInclude from '../../../components/WhatWeInclude.astro';
import FormatGrid from '../../../components/FormatGrid.astro';
import PricingTable from '../../../components/PricingTable.astro';
import CoachingAddOn from '../../../components/CoachingAddOn.astro';
import ReclubSection from '../../../components/ReclubSection.astro';
import RulesTable from '../../../components/RulesTable.astro';
import LeaderboardSection from '../../../components/LeaderboardSection.astro';
---
<Base title="Late Evening Group · Casa De Padel · Padel Community India (PCI)" description="A private padel subscription for intermediate and above players in Kharadi, Pune. Two courts, 24 members, weeknight evenings at Casa De Padel.">

<!-- HERO -->
<section class="hero" style="border-bottom: 1px solid var(--rule); padding-top: 10vh;">
  <div class="hero-img" style="background-image: url('/images/hero-cdp.jpg');"></div>
  <div class="hero-bg-word">PADEL</div>

  <div class="hero-eyebrow">PCI · Casa De Padel, Kharadi · Pune</div>

  <h1 class="hero-title">
    Casa De Padel.<br>
    <span>Late Evening.</span>
  </h1>

  <p class="hero-sub">
    A private padel subscription for intermediate and above players in Kharadi, Pune. Two courts. Two 90-minute sessions per evening. Five nights a week. Somewhere between 8 PM and midnight, based on who's playing that day.
  </p>

  <div class="hero-meta">
    <div class="meta-item">
      <span class="meta-label">Venue</span>
      <span class="meta-value">Casa De Padel</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Time</span>
      <span class="meta-value">8 PM – Midnight</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Days</span>
      <span class="meta-value">Mon – Fri</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Spots</span>
      <span class="meta-value lime">24</span>
    </div>
  </div>
  <div class="hero-rule"></div>
</section>

<PainPoints />

<!-- WHAT THIS IS -->
<section>
  <div class="section-label">What this is</div>
  <div class="what-grid">
    <div>
      <h2 class="what-headline">
        Consistent courts.<br>
        Consistent people.<br>
        <span>Consistent game.</span>
      </h2>
    </div>
    <div class="what-body">
      <p><strong>Two courts at Casa De Padel. Every Monday to Friday.</strong><br>
      Match time is flexible between 8 PM and midnight, decided each day based on who's playing.</p>
      <p>Your spot is reserved. You show up, you play.</p>
      <p><strong>Two 90-minute sessions per evening.</strong><br>
      12 to 16 players per session. Total membership of 24.<br>
      Competitive enough to keep you sharp. Small enough that everyone knows everyone.</p>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section>
  <div class="section-label">How it works</div>
  <div class="how-cards">
    <div class="how-card">
      <div class="how-card-num">01</div>
      <div class="how-card-title">Register for the day</div>
      <div class="how-card-body">
        Members register for each evening on the <strong style="color:var(--lime)">Reclub private group</strong>: one tap, done. See who else is confirmed before you leave home. Each session runs with <strong style="color:var(--lime)">12 to 16 players</strong> across both courts.
      </div>
    </div>
    <div class="how-card">
      <div class="how-card-num">02</div>
      <div class="how-card-title">Show up and play</div>
      <div class="how-card-body">
        Courts are ready at your session time. Matches are organised on the night by the Day Leader.
        You play <strong style="color:var(--lime)">90 minutes per session.</strong> Two sessions run back to back across both courts.
      </div>
    </div>
    <div class="how-card">
      <div class="how-card-num">03</div>
      <div class="how-card-title">Play more when you can</div>
      <div class="how-card-body">
        When other members don't register, available slots open up.
        The more consistent you are, the more court time you get.
      </div>
    </div>
  </div>
</section>

<WhatWeInclude />

<FormatGrid />

<LeaderboardSection />

<PricingTable launchDate="July 2026 · Founding Batch" />

<CoachingAddOn />

<ReclubSection reclubUrl="https://reclub.co/clubs/@pune-cdp-9-11pm?at=XSFJOAUL" />

<!-- VENUE -->
<section>
  <div class="section-label">The venue</div>
  <div class="venue-wrap" style="grid-template-columns:1fr;">
    <div class="venue-left">
      <h2 class="venue-headline">Casa De Padel<br>at <span>Playshire.</span></h2>
      <div class="venue-address">Upper Kharadi Road, Kharadi, Pune</div>
      <p class="venue-desc">
        Playshire is one of Kharadi's best multi-sport complexes. A proper sports destination, not just a court booking. Casa De Padel sits inside it, which means you're playing in a facility built for people who take sport seriously. Rated 4.7 on Playo, open 24x7, and located in the heart of Kharadi's tech and residential corridor. Easy to get to after work, easy to stick to as a routine. Two great cafes at the venue make it easy to wind down after a session.
      </p>
      <div class="venue-sports">
        <span class="venue-sport-tag active">Padel</span>
        <span class="venue-sport-tag">Badminton</span>
        <span class="venue-sport-tag">Football</span>
        <span class="venue-sport-tag">Box Cricket</span>
        <span class="venue-sport-tag">Snooker / Pool</span>
      </div>
    </div>
  </div>
</section>

<!-- WHO IS THIS FOR -->
<section>
  <div class="section-label">Who this is for</div>
  <div class="who-inner">
    <h2 class="who-headline">
      Players who are serious<br>about <span>getting better.</span>
    </h2>
    <ul class="who-list">
      <li><span><strong>Intermediate and above</strong>: you know your shots, you understand positioning, and you want competitive rallies, not beginner-friendly ones.</span></li>
      <li><span><strong>Consistent</strong>: you plan to show up most weeks, not occasionally. The club's quality depends on regular faces.</span></li>
      <li><span><strong>Done with logistics</strong>: you're tired of booking courts, chasing four people to confirm, or paying full walk-in rates.</span></li>
      <li><span><strong>Free most weeknights</strong>: you can make an evening session in Kharadi between 8 PM and midnight, Monday to Friday.</span></li>
    </ul>
  </div>
</section>

<RulesTable />

<!-- CTA -->
<section class="cta-section">
  <h2 class="cta-headline">
    Ready to stop<br><span>hunting for courts?</span>
  </h2>
  <p class="cta-sub">Spots are extremely limited. Apply for an invite, we'll be in touch.</p>
  <div class="cta-spots">
    <div class="spot-dot"></div>
    Accepting applications · July 2026
  </div>
  <p style="font-family:'Bebas Neue',sans-serif;font-size:clamp(28px,4vw,48px);letter-spacing:0.06em;color:var(--lime);margin:12px 0 0;">24 spots only</p>
  <div class="cta-actions">
    <a href="https://wa.me/918007306165" class="cta-btn cta-btn-primary" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Apply on WhatsApp
    </a>
    <a href="https://reclub.co/clubs/@pune-cdp-9-11pm?at=XSFJOAUL" class="cta-btn cta-btn-secondary" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      Apply on Reclub
    </a>
  </div>
  <div style="margin-top:16px;font-size:13px;color:var(--muted);font-weight:300;">
    By applying you confirm you've read the <a href="/terms" style="color:var(--lime);text-decoration:none;border-bottom:1px solid rgba(200,245,74,0.3);">Terms &amp; Conditions →</a>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-brand">Padel Community India</div>
  <div class="footer-note">Casa De Padel, Kharadi · Mon–Fri · 8 PM–Midnight · Inter(+) · Intermediate &amp; Above</div>
</footer>

</Base>
