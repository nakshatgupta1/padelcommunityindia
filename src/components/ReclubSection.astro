---
export interface Props {
  reclubUrl?: string;
}

const { reclubUrl = 'https://reclub.co' } = Astro.props;
---
<section>
  <div class="section-label">The app</div>
  <div class="reclub-wrap">

    <div class="reclub-left">
      <h2 class="reclub-headline">
        Everything runs<br>through <span>Reclub.</span>
      </h2>
      <p class="reclub-desc">
        No WhatsApp chaos. No manual sign-up sheets. No "what time tonight?" messages an hour before.
        The subscription runs on <strong>Reclub</strong>, a dedicated app built exactly for sports groups like this one.
        Every member gets access. Everything happens in one place.
      </p>
      <a href={reclubUrl} target="_blank" rel="noopener" class="reclub-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="#C8F54A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;display:inline-block;vertical-align:middle;margin-right:6px">
          <rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>
        </svg>
        Private group · Subscribers only
      </a>
    </div>

    <div class="reclub-features">
      <div class="reclub-feature">
        <div class="reclub-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#C8F54A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
        </div>
        <div class="reclub-feature-text">
          <div class="reclub-feature-title">Register for tonight in one tap</div>
          <div class="reclub-feature-desc">See who's confirmed, who's on the waitlist. No chasing, no confirming over chat.</div>
        </div>
      </div>
      <div class="reclub-feature">
        <div class="reclub-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#C8F54A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
        </div>
        <div class="reclub-feature-text">
          <div class="reclub-feature-title">Vote on the format</div>
          <div class="reclub-feature-desc">Mexicano tonight or a round robin? The group votes, the Day Leader locks it in. Democracy on the court.</div>
        </div>
      </div>
      <div class="reclub-feature">
        <div class="reclub-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#C8F54A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
        </div>
        <div class="reclub-feature-text">
          <div class="reclub-feature-title">Team draws &amp; pairings</div>
          <div class="reclub-feature-desc">Teams divided fairly and randomly. No awkward picking, no same pairs every night.</div>
        </div>
      </div>
      <div class="reclub-feature">
        <div class="reclub-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#C8F54A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        </div>
        <div class="reclub-feature-text">
          <div class="reclub-feature-title">Track your history &amp; stats</div>
          <div class="reclub-feature-desc">Sessions played, wins, partners — your padel record, all in one place over time.</div>
        </div>
      </div>
      <div class="reclub-feature">
        <div class="reclub-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#C8F54A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div class="reclub-feature-text">
          <div class="reclub-feature-title">Community chat</div>
          <div class="reclub-feature-desc">Talk game, plan sessions, share clips without it getting buried in a family WhatsApp group.</div>
        </div>
      </div>
      <div class="reclub-feature">
        <div class="reclub-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#C8F54A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <div class="reclub-feature-text">
          <div class="reclub-feature-title">Leaderboards &amp; competitions</div>
          <div class="reclub-feature-desc">Live scores during Americanos and Mexicanos. Standings that update as you play.</div>
        </div>
      </div>
    </div>

  </div>
</section>
