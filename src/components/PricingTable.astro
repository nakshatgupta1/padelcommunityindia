---
export interface Props {
  launchDate?: string;
  subheadline?: string;
  tbc?: boolean;
}

const {
  launchDate = 'July 2026 · Founding Batch',
  subheadline = 'Everything included. Courts, balls, mineral water, tournaments, monthly social events and a welcome kit. The longer you commit, the better the rate.',
  tbc = false,
} = Astro.props;
---
<section id="pricing">
  <div class="section-label">Membership</div>

  <div class="pricing-launch">
    <div class="pricing-launch-date">{launchDate}</div>
    <h2 class="pricing-launch-headline">Choose your <span>commitment.</span></h2>
    <p class="pricing-launch-sub">{subheadline}</p>
  </div>

  {tbc ? (
    <div class="placeholder-block" style="max-width:680px;">
      <div class="placeholder-label">Pricing</div>
      <div class="placeholder-text">[PRICING TBD] Coming soon</div>
    </div>
  ) : (
    <div class="pricing-cards">

      <!-- MONTHLY -->
      <div class="pricing-card">
        <div class="pc-tag-wrap"></div>
        <div class="pc-plan">Monthly</div>
        <div class="pc-price-wrap">
          <div class="pc-price"><span class="pc-currency">₹</span>10,000<span class="pc-per">/mo</span></div>
        </div>
        <div class="pc-divider"></div>
        <div class="pc-note">Full flexibility.<br>Spot not guaranteed for the following month.</div>
      </div>

      <!-- 3 MONTHS — FEATURED -->
      <div class="pricing-card pricing-card-featured">
        <div class="pc-tag-wrap"><span class="pc-tag">Most popular</span></div>
        <div class="pc-plan">3 Months</div>
        <div class="pc-price-wrap">
          <div class="pc-price"><span class="pc-currency">₹</span>9,000<span class="pc-per">/mo</span></div>
        </div>
        <div class="pc-total">Total <span>₹27,000</span></div>
        <div class="pc-divider"></div>
        <div class="pc-note">Spot secured for the full quarter.</div>
      </div>

      <!-- 6 MONTHS -->
      <div class="pricing-card">
        <div class="pc-tag-wrap"></div>
        <div class="pc-plan">6 Months</div>
        <div class="pc-price-wrap">
          <div class="pc-price"><span class="pc-currency">₹</span>8,000<span class="pc-per">/mo</span></div>
        </div>
        <div class="pc-total">Total <span>₹48,000</span></div>
        <div class="pc-divider"></div>
        <div class="pc-note">Spot locked for six months.<br>Continuity guaranteed.</div>
      </div>

      <!-- ANNUAL -->
      <div class="pricing-card pricing-card-annual">
        <div class="pc-tag-wrap"><span class="pc-tag-outline">Best value</span></div>
        <div class="pc-plan">Annual</div>
        <div class="pc-price-wrap">
          <div class="pc-price"><span class="pc-currency">₹</span>6,000<span class="pc-per">/mo</span></div>
        </div>
        <div class="pc-total">Total <span>₹72,000</span></div>
        <div class="pc-divider"></div>
        <div class="pc-note">Spot locked for the full year.</div>
      </div>

    </div>
  )}

</section>
